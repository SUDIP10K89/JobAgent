// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USER (NextAuth)
// =====================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  image         String?
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  jobs          Job[]
  notifications Notification[]
  settings      Setting[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================
// USER KNOWLEDGE BASE
// =====================================================

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  email        String
  phone        String?
  location     String?
  linkedin     String?
  github       String?
  portfolio    String?
  headline     String?
  summary      String?
  // JSON arrays stored as text
  skills       String   @default("[]")
  projects     String   @default("[]")
  education    String   @default("[]")
  experience   String   @default("[]")
  achievements String   @default("[]")
  preferences  String   @default("{}")
  // Search preferences
  jobTitles    String   @default("[]")
  locations    String   @default("[]")
  remoteOnly   Boolean  @default(false)
  minSalary    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =====================================================
// JOB LISTINGS
// =====================================================

model Job {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      String   @default("manual")
  externalId  String?
  company     String
  title       String
  salary      String?
  experience  String?
  location    String?
  remote      Boolean  @default(false)
  url         String?
  deadline    String?
  description String?
  tags        String   @default("[]")
  matchScore  Int?
  matchResult String?
  atsScore    Int?
  atsResult   String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]

  @@index([source, externalId])
  @@index([matchScore])
  @@index([userId])
}

// =====================================================
// APPLICATIONS
// =====================================================

model Application {
  id              String   @id @default(cuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status          String   @default("draft")
  appliedAt       DateTime?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  followUpCount   Int      @default(0)
  resumeContent   String?
  coverLetter     String?
  screeningQA     String?
  interviewPrep   String?
  networkingMsg   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([jobId])
}

// =====================================================
// NOTIFICATIONS
// =====================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  jobId     String?
  applicationId String?
  read      Boolean  @default(false)
  priority  String   @default("normal")
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// =====================================================
// SETTINGS (key-value store, per user)
// =====================================================

model Setting {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String
  value  String

  @@unique([userId, key])
}
